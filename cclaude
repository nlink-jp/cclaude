#!/usr/bin/env bash
# cclaude — Containerized Claude Code
# https://github.com/nlink-jp/cclaude
set -euo pipefail

CCC_VERSION="0.1.0"
CCC_DEFAULT_IMAGE="cclaude:latest"
CCC_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/cclaude"
CCC_CONFIG_FILE="${CCC_CONFIG_DIR}/config.toml"

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

die() {
    printf 'cclaude: error: %s\n' "$1" >&2
    exit 1
}

warn() {
    printf 'cclaude: warning: %s\n' "$1" >&2
}

# ---------------------------------------------------------------------------
# Minimal TOML reader (flat key = "value" within [section])
# ---------------------------------------------------------------------------

# config_get SECTION KEY [DEFAULT]
config_get() {
    local section="$1" key="$2" default="${3:-}"
    if [[ ! -f "$CCC_CONFIG_FILE" ]]; then
        printf '%s' "$default"
        return
    fi
    local in_section=false value=""
    while IFS= read -r line || [[ -n "$line" ]]; do
        # strip inline comments and trim
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [[ -z "$line" ]] && continue

        if [[ "$line" =~ ^\[([a-zA-Z_][a-zA-Z0-9_]*)\]$ ]]; then
            if [[ "${BASH_REMATCH[1]}" == "$section" ]]; then
                in_section=true
            else
                $in_section && break
                in_section=false
            fi
            continue
        fi
        if $in_section && [[ "$line" =~ ^([a-zA-Z_][a-zA-Z0-9_]*)\ *=\ *\"?([^\"]*)\"?$ ]]; then
            if [[ "${BASH_REMATCH[1]}" == "$key" ]]; then
                value="${BASH_REMATCH[2]}"
            fi
        fi
    done < "$CCC_CONFIG_FILE"
    printf '%s' "${value:-$default}"
}

# config_get_array SECTION KEY — read a TOML inline array like [8080, 11434]
# Prints one element per line. Returns nothing if key is absent or commented.
config_get_array() {
    local section="$1" key="$2"
    local raw
    raw="$(config_get "$section" "$key" "")"
    [[ -z "$raw" ]] && return
    # Strip brackets, split on comma, trim whitespace
    raw="${raw#\[}"
    raw="${raw%\]}"
    local IFS=','
    for item in $raw; do
        item="${item#"${item%%[![:space:]]*}"}"
        item="${item%"${item##*[![:space:]]}"}"
        [[ -n "$item" ]] && printf '%s\n' "$item"
    done
}

# read_port_list ARRAY_NAME ENV_VAR SECTION KEY
# Populate a bash array from env var (comma-separated) or TOML config array.
read_port_list() {
    local arr_name="$1" env_name="$2" section="$3" key="$4"
    local env_val="${!env_name:-}"
    if [[ -n "$env_val" ]]; then
        local IFS=','
        for p in $env_val; do
            p="${p#"${p%%[![:space:]]*}"}"
            p="${p%"${p##*[![:space:]]}"}"
            [[ -n "$p" ]] && eval "${arr_name}+=(\"$p\")"
        done
    else
        local p
        while IFS= read -r p; do
            [[ -n "$p" ]] && eval "${arr_name}+=(\"$p\")"
        done < <(config_get_array "$section" "$key")
    fi
}

# ---------------------------------------------------------------------------
# Resolve a config value: env var > config file > default
# ---------------------------------------------------------------------------

# resolve ENV_VAR SECTION KEY DEFAULT
resolve() {
    local env_var="$1" section="$2" key="$3" default="$4"
    local env_val="${!env_var:-}"
    if [[ -n "$env_val" ]]; then
        printf '%s' "$env_val"
    else
        config_get "$section" "$key" "$default"
    fi
}

# ---------------------------------------------------------------------------
# Container runtime detection
# ---------------------------------------------------------------------------

detect_runtime() {
    local configured
    configured="$(resolve CCC_RUNTIME container runtime auto)"
    if [[ "$configured" != "auto" ]]; then
        if [[ "${CCC_DRY_RUN:-}" != "1" ]]; then
            command -v "$configured" &>/dev/null || die "Configured runtime '$configured' not found in PATH."
        fi
        printf '%s' "$configured"
        return
    fi
    if command -v podman &>/dev/null; then
        printf 'podman'
    elif command -v docker &>/dev/null; then
        printf 'docker'
    else
        if [[ "${CCC_DRY_RUN:-}" == "1" ]]; then
            printf 'podman'
            return
        fi
        die "No container runtime found. Install podman or docker."
    fi
}

# ---------------------------------------------------------------------------
# Image management
# ---------------------------------------------------------------------------

image_exists() {
    local runtime="$1" image="$2"
    "$runtime" image inspect "$image" &>/dev/null
}

locate_dockerfile() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    local candidates=(
        "${script_dir}/Dockerfile"
        "${CCC_CONFIG_DIR}/Dockerfile"
    )
    for f in "${candidates[@]}"; do
        if [[ -f "$f" ]]; then
            printf '%s' "$f"
            return
        fi
    done
    die "Dockerfile not found. Searched: ${candidates[*]}"
}

build_image() {
    local runtime="$1" image="$2"
    local dockerfile
    dockerfile="$(locate_dockerfile)"
    local context_dir
    context_dir="$(dirname "$dockerfile")"

    local go_ver node_ver
    go_ver="$(resolve CCC_GO_VERSION toolchain go_version 1.23.4)"
    node_ver="$(resolve CCC_NODE_VERSION toolchain node_version 20)"

    printf 'cclaude: building image %s ...\n' "$image" >&2
    "$runtime" build --no-cache \
        --build-arg "GO_VERSION=${go_ver}" \
        --build-arg "NODE_VERSION=${node_ver}" \
        -t "$image" \
        -f "$dockerfile" \
        "$context_dir"
    printf 'cclaude: image %s built successfully.\n' "$image" >&2
}

ensure_image() {
    local runtime="$1" image="$2"
    if ! image_exists "$runtime" "$image"; then
        printf 'cclaude: image %s not found. Building...\n' "$image" >&2
        build_image "$runtime" "$image"
        return
    fi
    # Warn if Dockerfile is newer than the image
    local dockerfile
    dockerfile="$(locate_dockerfile 2>/dev/null)" || return
    local img_epoch df_epoch
    # Get image creation time as epoch (UTC)
    img_epoch="$("$runtime" image inspect --format '{{.Created.Unix}}' "$image" 2>/dev/null)" \
        || return
    df_epoch="$(stat -f "%m" "$dockerfile" 2>/dev/null)" \
        || df_epoch="$(stat -c "%Y" "$dockerfile" 2>/dev/null)" || return
    if [[ "$df_epoch" -gt "$img_epoch" ]]; then
        warn "Dockerfile is newer than image '$image'. Run 'cclaude --build' to rebuild."
    fi
}

# ---------------------------------------------------------------------------
# Prepare container-specific Claude home
# ---------------------------------------------------------------------------

# Container uses its own copy of ~/.claude so that settings (sandbox, etc.)
# can differ from the host.  On first run the host's Claude home is copied;
# after that the container copy is reused as-is.

CCC_CONTAINER_CLAUDE_HOME="${CCC_CONFIG_DIR}/claude-home"
CCC_CONTAINER_CLAUDE_JSON="${CCC_CONFIG_DIR}/claude.json"

prepare_claude_home() {
    local host_claude_home="$1"

    if [[ ! -d "$CCC_CONTAINER_CLAUDE_HOME" ]]; then
        if [[ -d "$host_claude_home" ]]; then
            printf 'cclaude: initializing container Claude home from %s ...\n' "$host_claude_home" >&2
            cp -a "$host_claude_home" "$CCC_CONTAINER_CLAUDE_HOME"
        else
            mkdir -p "$CCC_CONTAINER_CLAUDE_HOME"
        fi
        # Disable sandbox — the container itself provides isolation
        cat > "${CCC_CONTAINER_CLAUDE_HOME}/settings.local.json" <<'SETTINGS'
{
  "sandbox": {
    "enabled": false
  }
}
SETTINGS
        printf 'cclaude: sandbox disabled in container settings.\n' >&2
    fi

    # Copy ~/.claude.json (session/auth state) on first run
    if [[ ! -f "$CCC_CONTAINER_CLAUDE_JSON" ]]; then
        local host_claude_json="${HOME}/.claude.json"
        if [[ -f "$host_claude_json" ]]; then
            cp -a "$host_claude_json" "$CCC_CONTAINER_CLAUDE_JSON"
        else
            printf '{}' > "$CCC_CONTAINER_CLAUDE_JSON"
        fi
    fi
}

# ---------------------------------------------------------------------------
# SSH agent forwarding (socket mount — Linux only)
# ---------------------------------------------------------------------------

setup_ssh_agent_mount() {
    local runtime="$1"
    # macOS: Unix domain sockets cannot pass through virtiofs.
    # Use --ssh mode instead for SSH agent forwarding on macOS.
    if [[ "$(uname -s)" == "Darwin" ]]; then
        return
    fi
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        run_args+=(-v "${SSH_AUTH_SOCK}:/ssh-agent" -e "SSH_AUTH_SOCK=/ssh-agent")
    fi
}

# ---------------------------------------------------------------------------
# SSH mode: run container with sshd, connect via ssh -A for agent forwarding
# ---------------------------------------------------------------------------

# Use a random high port to avoid conflicts and reduce exposure
CCC_SSH_PORT="${CCC_SSH_PORT:-$((49152 + RANDOM % 16384))}"
CCC_CONTAINER_NAME="cclaude-ssh-$$"

run_claude_ssh() {
    local runtime image host_claude_home project_dir
    runtime="$(detect_runtime)"
    image="$(resolve CCC_IMAGE container image "$CCC_DEFAULT_IMAGE")"
    host_claude_home="$(resolve CCC_CLAUDE_HOME paths claude_home "$HOME/.claude")"
    host_claude_home="${host_claude_home/#\~/$HOME}"
    project_dir="$(pwd)"

    if [[ "${CCC_DRY_RUN:-}" != "1" ]]; then
        ensure_image "$runtime" "$image"
        prepare_claude_home "$host_claude_home"
    fi

    # Generate ephemeral SSH key pair (created per session, destroyed on exit)
    local ssh_key=""
    local pubkey="DRY_RUN_PLACEHOLDER"
    if [[ "${CCC_DRY_RUN:-}" != "1" ]]; then
        ssh_key="$(mktemp -d)/cclaude_key"
        ssh-keygen -t ed25519 -f "$ssh_key" -N "" -C "cclaude-ephemeral" -q
        pubkey="$(cat "${ssh_key}.pub")"
    fi

    local -a run_args=(
        run -d --rm
        --name "${CCC_CONTAINER_NAME}"
        --hostname cclaude
        -v "${project_dir}:${project_dir}"
        -w "${project_dir}"
        -v "${CCC_CONTAINER_CLAUDE_HOME}:/root/.claude"
        -v "${CCC_CONTAINER_CLAUDE_JSON}:/root/.claude.json"
        -p "127.0.0.1:${CCC_SSH_PORT}:22"
        -e "TERM=${TERM:-xterm-256color}"
    )

    # API key
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        run_args+=(-e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
    fi

    # Git identity
    local git_name git_email
    git_name="$(git config user.name 2>/dev/null || true)"
    git_email="$(git config user.email 2>/dev/null || true)"
    if [[ -n "$git_name" ]]; then
        run_args+=(-e "GIT_AUTHOR_NAME=${git_name}" -e "GIT_COMMITTER_NAME=${git_name}")
    fi
    if [[ -n "$git_email" ]]; then
        run_args+=(-e "GIT_AUTHOR_EMAIL=${git_email}" -e "GIT_COMMITTER_EMAIL=${git_email}")
    fi

    # Host network access
    local host_gw
    if [[ "$runtime" == "podman" ]]; then
        host_gw="host.containers.internal"
        run_args+=(--add-host "${host_gw}:host-gateway")
        run_args+=(--security-opt "label=disable")
    else
        host_gw="host.docker.internal"
        run_args+=(--add-host "${host_gw}:host-gateway")
    fi

    # Port forwarding (socat) and publishing
    local -a forward_ports=()
    read_port_list forward_ports "CCC_FORWARD_PORTS" "network" "forward_ports"
    local -a publish_ports=()
    read_port_list publish_ports "CCC_PUBLISH_PORTS" "network" "publish_ports"
    if [[ ${#publish_ports[@]} -gt 0 ]]; then
        for p in "${publish_ports[@]}"; do
            run_args+=(-p "127.0.0.1:${p}:${p}")
        done
    fi

    # Build entrypoint: inject pubkey, start socat forwarders, start sshd
    local init_script="mkdir -p /root/.ssh && chmod 700 /root/.ssh"
    init_script+=" && printf '%s\\n' '${pubkey}' > /root/.ssh/authorized_keys"
    init_script+=" && chmod 600 /root/.ssh/authorized_keys"
    local socat_cmds=""
    if [[ ${#forward_ports[@]} -gt 0 ]]; then
        for p in "${forward_ports[@]}"; do
            socat_cmds+="socat TCP-LISTEN:${p},fork,reuseaddr TCP:${host_gw}:${p} & "
        done
    fi
    init_script+=" && ${socat_cmds}/usr/sbin/sshd -D"

    if [[ "${CCC_DRY_RUN:-}" == "1" ]]; then
        printf '%s' "$runtime"
        printf ' %s' "${run_args[@]}"
        printf ' %s bash -c "%s"\n' "$image" "$init_script"
        printf 'ssh -A -t -p %s -o StrictHostKeyChecking=no root@127.0.0.1 claude' "$CCC_SSH_PORT"
        for arg in "$@"; do
            printf ' %s' "$arg"
        done
        printf '\n'
        return 0
    fi

    # Clean up on exit: stop container and remove ephemeral key
    # Capture variables for use in trap (avoid unbound variable errors)
    local _cleanup_runtime="$runtime"
    local _cleanup_container="$CCC_CONTAINER_NAME"
    local _cleanup_key="${ssh_key:-}"
    cleanup_ssh_container() {
        "$_cleanup_runtime" stop "$_cleanup_container" &>/dev/null || true
        if [[ -n "$_cleanup_key" ]]; then
            rm -f "$_cleanup_key" "${_cleanup_key}.pub"
            rmdir "$(dirname "$_cleanup_key")" 2>/dev/null || true
        fi
    }
    trap cleanup_ssh_container EXIT INT TERM

    # Stop orphaned cclaude-ssh containers from previous interrupted sessions.
    # Only stops containers that are no longer attached to a running cclaude process.
    local orphan
    for orphan in $("$runtime" ps -q --filter "name=cclaude-ssh-" 2>/dev/null); do
        local orphan_name
        orphan_name="$("$runtime" inspect --format '{{.Name}}' "$orphan" 2>/dev/null)" || continue
        # Extract PID from container name (cclaude-ssh-<PID>)
        local orphan_pid="${orphan_name##*-}"
        # If the parent process is no longer running, this is an orphan
        if ! kill -0 "$orphan_pid" 2>/dev/null; then
            "$runtime" stop "$orphan" &>/dev/null || true
        fi
    done

    # Start container with sshd
    local start_err
    if ! start_err="$("$runtime" "${run_args[@]}" "$image" bash -c "$init_script" 2>&1)"; then
        printf '%s\n' "$start_err" >&2
        if [[ "$start_err" == *"proxy already running"* ]] || [[ "$start_err" == *"address already in use"* ]]; then
            warn "A port conflict was detected. Published ports may already be in use."
            warn "Check config: publish_ports in ~/.config/cclaude/config.toml"
            warn "To release ports, restart Podman Machine: podman machine stop && podman machine start"
        fi
        die "Failed to start container."
    fi

    # Wait for sshd to be ready
    local retries=0
    while ! ssh -q -i "$ssh_key" -p "$CCC_SSH_PORT" \
            -o StrictHostKeyChecking=no -o BatchMode=yes \
            -o UserKnownHostsFile=/dev/null \
            root@127.0.0.1 true 2>/dev/null; do
        retries=$((retries + 1))
        if [[ $retries -ge 30 ]]; then
            die "Timed out waiting for container sshd on port ${CCC_SSH_PORT}."
        fi
        sleep 0.2
    done

    # Connect with agent forwarding and run claude
    ssh -A -t \
        -i "$ssh_key" \
        -p "$CCC_SSH_PORT" \
        -o StrictHostKeyChecking=no \
        -o UserKnownHostsFile=/dev/null \
        -o LogLevel=ERROR \
        root@127.0.0.1 \
        "cd '${project_dir}' && claude $*"
}

# ---------------------------------------------------------------------------
# Run Claude Code in container
# ---------------------------------------------------------------------------

run_claude() {
    local runtime image host_claude_home project_dir
    runtime="$(detect_runtime)"
    image="$(resolve CCC_IMAGE container image "$CCC_DEFAULT_IMAGE")"
    host_claude_home="$(resolve CCC_CLAUDE_HOME paths claude_home "$HOME/.claude")"
    # Expand ~ if present
    host_claude_home="${host_claude_home/#\~/$HOME}"
    project_dir="$(pwd)"

    if [[ "${CCC_DRY_RUN:-}" != "1" ]]; then
        ensure_image "$runtime" "$image"
        prepare_claude_home "$host_claude_home"
    fi

    # Verify TTY
    if [[ ! -t 0 ]]; then
        warn "stdin is not a TTY. Claude Code requires an interactive terminal."
    fi

    local -a run_args=(
        run --rm -it
        --hostname cclaude
        # Mount project at same absolute path for memory compatibility
        -v "${project_dir}:${project_dir}"
        -w "${project_dir}"
        # Container-specific Claude home (copied from host on first run)
        -v "${CCC_CONTAINER_CLAUDE_HOME}:/root/.claude"
        -v "${CCC_CONTAINER_CLAUDE_JSON}:/root/.claude.json"
        # Terminal
        -e "TERM=${TERM:-xterm-256color}"
    )

    # API key (optional — subscription auth via OAuth is also supported)
    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        run_args+=(-e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
    fi

    # Git identity
    local git_name git_email
    git_name="$(git config user.name 2>/dev/null || true)"
    git_email="$(git config user.email 2>/dev/null || true)"
    if [[ -n "$git_name" ]]; then
        run_args+=(-e "GIT_AUTHOR_NAME=${git_name}" -e "GIT_COMMITTER_NAME=${git_name}")
    fi
    if [[ -n "$git_email" ]]; then
        run_args+=(-e "GIT_AUTHOR_EMAIL=${git_email}" -e "GIT_COMMITTER_EMAIL=${git_email}")
    fi

    # SSH agent forwarding (socket mount — Linux only)
    setup_ssh_agent_mount "$runtime"

    # Host network access
    local host_gw
    if [[ "$runtime" == "podman" ]]; then
        host_gw="host.containers.internal"
        run_args+=(--add-host "${host_gw}:host-gateway")
        run_args+=(--security-opt "label=disable")
    else
        host_gw="host.docker.internal"
        run_args+=(--add-host "${host_gw}:host-gateway")
    fi

    # Port forwarding: container localhost → host localhost via socat
    local -a forward_ports=()
    read_port_list forward_ports "CCC_FORWARD_PORTS" "network" "forward_ports"

    # Port publishing: container port → host port via -p
    local -a publish_ports=()
    read_port_list publish_ports "CCC_PUBLISH_PORTS" "network" "publish_ports"
    if [[ ${#publish_ports[@]} -gt 0 ]]; then
        for p in "${publish_ports[@]}"; do
            run_args+=(-p "127.0.0.1:${p}:${p}")
        done
    fi

    # Build container command
    local -a container_cmd
    if [[ ${#forward_ports[@]} -gt 0 ]]; then
        # Start socat forwarders in background, then exec claude
        local socat_cmds=""
        for p in "${forward_ports[@]}"; do
            socat_cmds+="socat TCP-LISTEN:${p},fork,reuseaddr TCP:${host_gw}:${p} & "
        done
        container_cmd=(bash -c "${socat_cmds}exec claude \"\$@\"" -- "$@")
    else
        container_cmd=(claude "$@")
    fi

    if [[ "${CCC_DRY_RUN:-}" == "1" ]]; then
        printf '%s' "$runtime"
        printf ' %s' "${run_args[@]}"
        printf ' %s' "$image"
        for arg in "${container_cmd[@]}"; do
            printf ' %s' "$arg"
        done
        printf '\n'
        return 0
    fi

    exec "$runtime" "${run_args[@]}" "$image" "${container_cmd[@]}"
}

# ---------------------------------------------------------------------------
# Run shell in container (debug)
# ---------------------------------------------------------------------------

run_shell() {
    local runtime image host_claude_home project_dir
    runtime="$(detect_runtime)"
    image="$(resolve CCC_IMAGE container image "$CCC_DEFAULT_IMAGE")"
    host_claude_home="$(resolve CCC_CLAUDE_HOME paths claude_home "$HOME/.claude")"
    host_claude_home="${host_claude_home/#\~/$HOME}"
    project_dir="$(pwd)"

    if [[ "${CCC_DRY_RUN:-}" != "1" ]]; then
        ensure_image "$runtime" "$image"
        prepare_claude_home "$host_claude_home"
    fi

    local -a run_args=(
        run --rm -it
        --hostname cclaude
        -v "${project_dir}:${project_dir}"
        -w "${project_dir}"
        -v "${CCC_CONTAINER_CLAUDE_HOME}:/root/.claude"
        -v "${CCC_CONTAINER_CLAUDE_JSON}:/root/.claude.json"
        -e "TERM=${TERM:-xterm-256color}"
    )

    if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
        run_args+=(-e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
    fi

    if [[ "$runtime" == "podman" ]]; then
        run_args+=(--security-opt "label=disable")
    fi

    if [[ "${CCC_DRY_RUN:-}" == "1" ]]; then
        printf '%s' "$runtime"
        printf ' %s' "${run_args[@]}"
        printf ' %s bash\n' "$image"
        return 0
    fi

    exec "$runtime" "${run_args[@]}" "$image" bash
}

# ---------------------------------------------------------------------------
# Print resolved configuration
# ---------------------------------------------------------------------------

show_config() {
    local runtime image host_claude_home
    runtime="$(detect_runtime)"
    image="$(resolve CCC_IMAGE container image "$CCC_DEFAULT_IMAGE")"
    host_claude_home="$(resolve CCC_CLAUDE_HOME paths claude_home "$HOME/.claude")"
    host_claude_home="${host_claude_home/#\~/$HOME}"

    cat <<EOF
cclaude v${CCC_VERSION}

[resolved]
runtime            = ${runtime}
image              = ${image}
mode               = $(resolve CCC_MODE container mode direct)
host_claude_home   = ${host_claude_home}
container_home     = ${CCC_CONTAINER_CLAUDE_HOME}
config_file        = ${CCC_CONFIG_FILE}
project_dir        = $(pwd)

[toolchain] (used at image build time)
go_version    = $(resolve CCC_GO_VERSION toolchain go_version 1.23.4)
node_version  = $(resolve CCC_NODE_VERSION toolchain node_version 20)

[network]
forward_ports = $(
    local env_ports="${CCC_FORWARD_PORTS:-}"
    if [[ -n "$env_ports" ]]; then
        printf '%s' "$env_ports"
    else
        local ports
        ports="$(config_get_array "network" "forward_ports" | paste -sd, -)"
        printf '%s' "${ports:-(none)}"
    fi
)

[environment]
ANTHROPIC_API_KEY = ${ANTHROPIC_API_KEY:+(set)}${ANTHROPIC_API_KEY:-(not set)}
SSH_AUTH_SOCK     = ${SSH_AUTH_SOCK:-(not set)}
EOF
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
cclaude — Containerized Claude Code v${CCC_VERSION}

Run Claude Code inside an isolated container with only the current project
directory mounted. Claude Code state (~/.claude) is persisted on the host.

Usage:
  cclaude [options] [-- claude-args...]

Options:
  --build        Build or rebuild the container image
  --ssh          Connect via SSH with agent forwarding (enables host SSH keys)
  --shell        Open a bash shell inside the container (debug)
  --config       Show resolved configuration
  --version      Print version
  --help         Show this help

Examples:
  cclaude                        Launch Claude Code for the current directory
  cclaude --ssh                  Launch with SSH agent forwarding (1Password, etc.)
  cclaude --build                Build the container image
  cclaude -- -p "run tests"      Pass arguments to claude

Authentication:
  API key:        Set ANTHROPIC_API_KEY environment variable.
  Subscription:   Run 'cclaude' and follow the OAuth login URL shown in the
                  terminal. Open the URL in your host browser. The login
                  state is persisted in ~/.claude across sessions.

Configuration:
  File: \${XDG_CONFIG_HOME:-~/.config}/cclaude/config.toml
  Environment variables override config file values.
  See config.toml.example for all options.

Environment:
  ANTHROPIC_API_KEY   API key for Claude (optional if using subscription)
  CCC_RUNTIME         Container runtime: "podman", "docker", "auto"
  CCC_IMAGE           Container image name (default: cclaude:latest)
  CCC_CLAUDE_HOME     Path to Claude home directory (default: ~/.claude)
  CCC_DRY_RUN=1       Print container command without executing

Repository: https://github.com/nlink-jp/cclaude
EOF
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

main() {
    case "${1:-}" in
        --build)
            local runtime image
            runtime="$(detect_runtime)"
            image="$(resolve CCC_IMAGE container image "$CCC_DEFAULT_IMAGE")"
            build_image "$runtime" "$image"
            ;;
        --ssh)
            shift
            run_claude_ssh "$@"
            ;;
        --shell)
            shift
            run_shell "$@"
            ;;
        --config)
            show_config
            ;;
        --version)
            printf 'cclaude %s\n' "$CCC_VERSION"
            ;;
        --help | -h)
            usage
            ;;
        --)
            shift
            run_default "$@"
            ;;
        --*)
            die "Unknown option: $1. Use --help for usage."
            ;;
        *)
            run_default "$@"
            ;;
    esac
}

run_default() {
    local mode
    mode="$(resolve CCC_MODE container mode direct)"
    if [[ "$mode" == "ssh" ]]; then
        run_claude_ssh "$@"
    else
        run_claude "$@"
    fi
}

main "$@"
